{
  "manifest_version": 3,
  "name": "Munra — Productivity Tracker",
  "version": "1.0.0",
  "description": "Automatically tracks browser activity and syncs with the Munra productivity platform.",
  "permissions": [
    "tabs",
    "storage",
    "idle",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://cognarc-it.vercel.app/*",
        "https://cognarc-it-1.onrender.com/*",
        "http://127.0.0.1:5000/*",
        "https://cognarc-it.vercel.app/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Munra"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
