# ============================================================================
# StudyTrack - Global .gitignore
# ============================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
.next/
out/
build/
*.tsbuildinfo

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime
pids/
*.pid
*.seed

# Coverage
coverage/
.nyc_output/

# Uploads (keep .gitkeep)
uploads/
!uploads/**/.gitkeep

# Prisma
backend/prisma/*.db
backend/prisma/*.db-journal

# Video files (large)
*.mp4
*.webm
*.mov

# Extension config
extension/browser/config.js

# Misc
*.bak
*.tmp
.eslintcache
