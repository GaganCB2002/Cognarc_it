generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  email            String             @unique
  name             String
  password         String?
  avatar           String?
  role             Role               @default(STUDENT)
  isapproved       Boolean            @default(false)
  emailverified    DateTime?          @db.Timestamp(6)
  provider         AuthProvider       @default(LOCAL)
  providerid       String?
  refreshtoken     String?
  settings         Json?
  createdat        DateTime           @default(now()) @db.Timestamp(6)
  updatedat        DateTime           @default(now()) @db.Timestamp(6)
  ActivityLog      ActivityLog[]
  BrowserTelemetry BrowserTelemetry[]
  Collection       Collection[]
  DesktopTelemetry DesktopTelemetry[]
  Document         Document[]
  LearningStreak   LearningStreak?
  LoginHistory     LoginHistory[]
  Note             Note[]
  Notification     Notification[]
  Otp              Otp[]
  Profile          Profile?
  Resource         Resource[]
  Session          Session[]
  StudySession     StudySession[]
  Task             Task[]

  @@index([email], map: "idx_user_email")
  @@index([provider], map: "idx_user_provider")
  @@index([role], map: "idx_user_role")
}

model Profile {
  id           String  @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid       String  @unique
  bio          String?
  targetrole   String?
  currentlevel String?
  weeklyhours  Int?
  careergoals  String?
  skills       Json?
  timezone     String?
  githuburl    String?
  linkedinurl  String?
  portfoliourl String?
  User         User    @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userid], map: "idx_profile_userid")
}

model LearningStreak {
  id             String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid         String    @unique
  currentstreak  Int       @default(0)
  longeststreak  Int       @default(0)
  lastactivedate DateTime? @db.Date
  User           User      @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userid], map: "idx_learningstreak_userid")
}

model StudySession {
  id        String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid    String
  topic     String
  duration  Int
  type      SessionType @default(GENERAL)
  notes     String?
  createdat DateTime    @default(now()) @db.Timestamp(6)
  User      User        @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdat], map: "idx_studysession_createdat")
  @@index([topic], map: "idx_studysession_topic")
  @@index([type], map: "idx_studysession_type")
  @@index([userid], map: "idx_studysession_userid")
}

model Task {
  id          String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid      String
  title       String
  description String?
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(TODO)
  duedate     DateTime?  @db.Timestamp(6)
  category    String?
  checklist   Json?
  createdat   DateTime   @default(now()) @db.Timestamp(6)
  updatedat   DateTime   @default(now()) @db.Timestamp(6)
  User        User       @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([category], map: "idx_task_category")
  @@index([duedate], map: "idx_task_duedate")
  @@index([priority], map: "idx_task_priority")
  @@index([status], map: "idx_task_status")
  @@index([userid], map: "idx_task_userid")
}

model Note {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid    String
  title     String
  content   String
  tags      String[] @default([])
  folderid  String?
  ispinned  Boolean  @default(false)
  createdat DateTime @default(now()) @db.Timestamp(6)
  updatedat DateTime @default(now()) @db.Timestamp(6)
  User      User     @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([folderid], map: "idx_note_folderid")
  @@index([ispinned], map: "idx_note_ispinned")
  @@index([tags], map: "idx_note_tags", type: Gin)
  @@index([userid], map: "idx_note_userid")
}

model Resource {
  id           String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid       String
  title        String
  type         ResourceType
  url          String?
  filekey      String?
  filesize     Int?
  mimetype     String?
  tags         String[]     @default([])
  collectionid String?
  isfavorite   Boolean      @default(false)
  isupload     Boolean      @default(false)
  createdat    DateTime     @default(now()) @db.Timestamp(6)
  updatedat    DateTime     @default(now()) @db.Timestamp(6)
  Document     Document?
  Collection   Collection?  @relation(fields: [collectionid], references: [id], onUpdate: NoAction)
  User         User         @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([collectionid], map: "idx_resource_collectionid")
  @@index([isfavorite], map: "idx_resource_isfavorite")
  @@index([isupload], map: "idx_resource_isupload")
  @@index([tags], map: "idx_resource_tags", type: Gin)
  @@index([type], map: "idx_resource_type")
  @@index([userid], map: "idx_resource_userid")
}

model Collection {
  id          String     @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid      String
  name        String
  description String?
  color       String?
  icon        String?
  createdat   DateTime   @default(now()) @db.Timestamp(6)
  updatedat   DateTime   @default(now()) @db.Timestamp(6)
  User        User       @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Resource    Resource[]

  @@index([userid], map: "idx_collection_userid")
}

model Notification {
  id        String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid    String
  title     String
  body      String
  type      NotificationType
  isread    Boolean          @default(false)
  actionurl String?
  createdat DateTime         @default(now()) @db.Timestamp(6)
  User      User             @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdat], map: "idx_notification_createdat")
  @@index([isread], map: "idx_notification_isread")
  @@index([type], map: "idx_notification_type")
  @@index([userid], map: "idx_notification_userid")
}

model ActivityLog {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid    String
  action    String
  entity    String
  entityid  String
  metadata  Json?
  createdat DateTime @default(now()) @db.Timestamp(6)
  User      User     @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([action], map: "idx_activitylog_action")
  @@index([createdat], map: "idx_activitylog_createdat")
  @@index([entity], map: "idx_activitylog_entity")
  @@index([userid], map: "idx_activitylog_userid")
}

model Document {
  id              String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid          String
  originalname    String
  mimetype        String
  size            Int
  storageprovider StorageProvider @default(LOCAL)
  storagekey      String          @unique
  publicurl       String?
  resourcetype    ResourceType
  status          DocumentStatus  @default(READY)
  folder          String?
  tags            String[]        @default([])
  metadata        Json?
  resourceid      String?         @unique
  createdat       DateTime        @default(now()) @db.Timestamp(6)
  updatedat       DateTime        @default(now()) @db.Timestamp(6)
  Resource        Resource?       @relation(fields: [resourceid], references: [id], onUpdate: NoAction)
  User            User            @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([folder], map: "idx_document_folder")
  @@index([status], map: "idx_document_status")
  @@index([storagekey], map: "idx_document_storagekey")
  @@index([tags], map: "idx_document_tags", type: Gin)
  @@index([userid], map: "idx_document_userid")
  @@index([userid, resourcetype], map: "idx_document_userid_type")
}

model BrowserTelemetry {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid    String
  url       String
  title     String?
  domain    String
  duration  Int
  category  String?
  timestamp DateTime @default(now()) @db.Timestamp(6)
  User      User     @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([category], map: "idx_browsertelemetry_category")
  @@index([domain], map: "idx_browsertelemetry_domain")
  @@index([timestamp], map: "idx_browsertelemetry_timestamp")
  @@index([userid], map: "idx_browsertelemetry_userid")
}

model DesktopTelemetry {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid      String
  activeapp   String
  windowtitle String
  processname String?
  duration    Int
  isidle      Boolean  @default(false)
  category    String?
  timestamp   DateTime @default(now()) @db.Timestamp(6)
  User        User     @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([activeapp], map: "idx_desktopelemetry_activeapp")
  @@index([category], map: "idx_desktopelemetry_category")
  @@index([timestamp], map: "idx_desktopelemetry_timestamp")
  @@index([userid], map: "idx_desktopelemetry_userid")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model LoginHistory {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid    String
  device    String?
  ip        String?
  browser   String?
  os        String?
  location  String?
  createdat DateTime @default(now()) @db.Timestamp(6)
  User      User     @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdat], map: "idx_loginhistory_createdat")
  @@index([userid], map: "idx_loginhistory_userid")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Otp {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid    String
  email     String
  code      String
  type      String    @default("LOGIN")
  expiresat DateTime  @db.Timestamp(6)
  usedat    DateTime? @db.Timestamp(6)
  createdat DateTime  @default(now()) @db.Timestamp(6)
  User      User      @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdat], map: "idx_otp_createdat")
  @@index([email], map: "idx_otp_email")
  @@index([userid], map: "idx_otp_userid")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Session {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userid     String
  token      String   @unique
  device     String?
  ip         String?
  lastactive DateTime @default(now()) @db.Timestamp(6)
  expiresat  DateTime @db.Timestamp(6)
  User       User     @relation(fields: [userid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token], map: "idx_session_token")
  @@index([userid], map: "idx_session_userid")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MENTOR
  STUDENT
  PREMIUM_USER
  GUEST
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
  MICROSOFT
}

enum SessionType {
  GENERAL
  CODING
  READING
  VIDEO
  QUIZ
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ResourceType {
  PDF
  VIDEO
  LINK
  CODE
  IMAGE
  OTHER
}

enum StorageProvider {
  LOCAL
  S3
  CLOUDINARY
  GITHUB
}

enum DocumentStatus {
  UPLOADING
  READY
  FAILED
  DELETED
}

enum NotificationType {
  REMINDER
  ACHIEVEMENT
  SYSTEM
  MENTOR
}
