# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Comma-separated CORS origins
FRONTEND_URL=http://localhost:3000

# ─── JWT Authentication ──────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# ─── Clerk Authentication ────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# ─── Database (PostgreSQL) ───────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres?sslmode=disable"

# ─── Supabase (optional) ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── AI / Gemini ─────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─── File Storage ────────────────────────────────────
STORAGE_PROVIDER=SUPABASE
SUPABASE_STORAGE_BUCKET=studytrack-uploads
LOCAL_STORAGE_PATH=./uploads

# ─── SMTP / Email ────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── S3 (Optional) ───────────────────────────────────
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ─── GitHub Storage (Optional) ───────────────────────
GITHUB_STORAGE_TOKEN=
GITHUB_STORAGE_OWNER=
GITHUB_STORAGE_REPO=
GITHUB_STORAGE_BRANCH=main
GITHUB_STORAGE_PATH=documents
