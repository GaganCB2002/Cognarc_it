# StudyTrack Backend - Environment Configuration
# Copy this file to .env and fill in your values.

# PostgreSQL database connection string (Prisma format with pg adapter)
# Format: prisma+postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require&connection_limit=10
DATABASE_URL="prisma+postgres://postgres:password@localhost:5432/studytrack?sslmode=disable"

# JWT Secret Key - CHANGE THIS in production to a strong random value
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your_jwt_secret_here_change_in_production"

# Frontend URL for CORS (comma-separated for multiple origins)
FRONTEND_URL="http://localhost:3000"

# Server port
PORT=5000

# Environment: development | production | test
NODE_ENV="development"

# SMTP Email Configuration (REQUIRED for OTP verification & password reset)
# Get Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"
SMTP_FROM="noreply@studytrack.app"
APP_NAME="StudyTrack"

# (Optional) OAuth credentials
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."
# GITHUB_CLIENT_ID="..."
# GITHUB_CLIENT_SECRET="..."

# (Optional) AI Service API Keys (at least one required for AI features)
# OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="your_gemini_api_key"

# Clerk Webhook Secret (optional - for Clerk user sync)
# CLERK_WEBHOOK_SECRET="whsec_..."

# ============================================================================
# Storage Configuration (for long-term document persistence)
# ============================================================================

# Storage provider: LOCAL (default), S3, or GITHUB
# LOCAL stores files on disk (persists across restarts, but not across servers)
# S3 stores files in AWS S3 or S3-compatible storage (Cloudflare R2, MinIO, etc.)
# GITHUB stores files in a GitHub repository under a "documents/" folder
STORAGE_PROVIDER="GITHUB"

# Local storage path (used when STORAGE_PROVIDER=LOCAL)
# Files are organized as: {LOCAL_STORAGE_PATH}/users/{userId_partition}/{userId}/{type}/{uuid}.ext
LOCAL_STORAGE_PATH="./uploads"

# S3 Configuration (used when STORAGE_PROVIDER=S3)
# S3_BUCKET="studytrack-uploads"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY="your-access-key"
# S3_SECRET_KEY="your-secret-key"
# S3_ENDPOINT="https://s3.amazonaws.com" # Use for S3-compatible storage like MinIO

# ============================================================================
# GitHub Storage Configuration (used when STORAGE_PROVIDER=GITHUB)
# ============================================================================
# Files are stored in a GitHub repository under a "documents/" folder.
# Create a GitHub Personal Access Token (classic) with 'repo' scope:
#   https://github.com/settings/tokens
GITHUB_STORAGE_TOKEN="your_github_personal_access_token"
# Repository owner (user or organization name)
GITHUB_STORAGE_OWNER="your_github_username"
# Repository name where files will be stored
GITHUB_STORAGE_REPO="studytrack-uploads"
# Branch to store files in (default: main)
# GITHUB_STORAGE_BRANCH="main"
# Path within the repo to store files (default: documents)
# GITHUB_STORAGE_PATH="documents"

# Public URL base for serving stored files (optional)
# For LOCAL: set to your server URL + /uploads path
# For S3: set to your S3 bucket URL or CDN
# STORAGE_PUBLIC_URL="http://localhost:5000/uploads"
