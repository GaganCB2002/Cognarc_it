# StudyTrack Backend - Environment Configuration
# Copy this file to .env and fill in your values.

# PostgreSQL database connection string
DATABASE_URL="prisma+postgres://postgres:password@localhost:5432/studytrack?sslmode=disable"

# JWT Secret Key - CHANGE THIS in production
JWT_SECRET="your_jwt_secret_here_change_in_production"

# Frontend URL for CORS (comma-separated for multiple origins)
FRONTEND_URL="http://localhost:3000"

# Server port
PORT=5000

# Environment: development | production | test
NODE_ENV="development"

# SMTP Email Configuration (OPTIONAL - Ethereal Email used by default for dev)
# In development, emails are sent via Ethereal (free, no config needed)
# View emails at: https://ethereal.email/
# For REAL email delivery, set SMTP_USER and SMTP_PASS:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your_email@gmail.com"
# SMTP_PASS="your_app_password"
SMTP_FROM="noreply@studytrack.app"
APP_NAME="StudyTrack"

# AI Service API Keys (required for AI features)
GEMINI_API_KEY="your_gemini_api_key"

# Storage Configuration
STORAGE_PROVIDER="LOCAL"
LOCAL_STORAGE_PATH="./uploads"
