{
  "manifest_version": 3,
  "name": "DocAgent — Smart Document Processor",
  "version": "1.0.0",
  "description": "Extract text from PDFs, images, and documents. Store, search, and recall everything instantly.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting",
    "downloads",
    "tabs",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "DocAgent",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "sandbox": {
    "pages": ["sandbox/ocr.html"]
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/*", "sandbox/*", "dashboard/*", "styles/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
