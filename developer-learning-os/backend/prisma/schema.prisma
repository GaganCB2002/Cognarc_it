generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String
  password      String?
  avatar        String?
  role          Role      @default(STUDENT)
  emailVerified DateTime?
  provider      AuthProvider @default(LOCAL)
  providerId    String?
  refreshToken  String?
  settings      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions       Session[]
  loginHistory   LoginHistory[]
  profile        Profile?
  learningStreak LearningStreak?
  studySessions  StudySession[]
  tasks          Task[]
  notes          Note[]
  resources      Resource[]
  collections    Collection[]
  notifications  Notification[]
  activityLogs   ActivityLog[]
  browserEvents  BrowserTelemetry[]
  desktopEvents  DesktopTelemetry[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  device    String?
  ip        String?
  lastActive DateTime @default(now())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  device    String?
  ip        String?
  browser   String?
  os        String?
  location  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  bio         String?
  targetRole  String?
  currentLevel String?
  weeklyHours Int?
  careerGoals String?
  skills      Json?
  timezone    String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningStreak {
  id             String   @id @default(uuid())
  userId         String   @unique
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActiveDate DateTime?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudySession {
  id        String   @id @default(uuid())
  userId    String
  topic     String
  duration  Int      // in seconds
  type      SessionType @default(GENERAL)
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  priority    Priority @default(MEDIUM)
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  category    String?
  checklist   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  tags      String[]
  folderId  String?
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Resource {
  id           String   @id @default(uuid())
  userId       String
  title        String
  type         ResourceType
  url          String?
  fileKey      String?
  tags         String[]
  collectionId String?
  isFavorite   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
}

model Collection {
  id          String   @id @default(uuid())
  userId      String
  name        String
  description String?
  color       String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resources   Resource[]
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      NotificationType
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MENTOR
  STUDENT
  PREMIUM_USER
  GUEST
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
  MICROSOFT
}

enum SessionType {
  GENERAL
  CODING
  READING
  VIDEO
  QUIZ
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ResourceType {
  PDF
  VIDEO
  LINK
  CODE
  IMAGE
  OTHER
}

enum NotificationType {
  REMINDER
  ACHIEVEMENT
  SYSTEM
  MENTOR
}

model BrowserTelemetry {
  id        String   @id @default(uuid())
  userId    String
  url       String
  title     String?
  domain    String
  duration  Int      // in seconds
  category  String?  // e.g. Documentation, Programming, Social Media
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DesktopTelemetry {
  id          String   @id @default(uuid())
  userId      String
  activeApp   String
  windowTitle String
  processName String?
  duration    Int      // in seconds
  isIdle      Boolean  @default(false)
  category    String?  // e.g. IDE, Terminal
  timestamp   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
